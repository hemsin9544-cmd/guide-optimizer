{
  "name": "guide-optimizer",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "prettier": "^3.7.4",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "10.9.8"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@google/generative-ai": "^0.24.1",
    "@mozilla/readability": "^0.6.0",
    "bullmq": "^5.80.8",
    "cheerio": "^1.2.0",
    "jsdom": "^29.1.1",
    "openai": "^6.48.0",
    "playwright": "^1.61.1",
    "turndown": "^7.2.4"
  }
}
